# AI model to use for localization and string translation.
# Use a Claude model (e.g. claude-3-haiku-20240307) or an OpenAI model
# (e.g. gpt-4o-mini, o1-mini). The provider is inferred from the model name.
AI_MODEL=gpt-4o-mini

# Provider API keys — only the one for AI_MODEL is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# App Store Connect API credentials.
# Generate a key at https://appstoreconnect.apple.com/access/integrations/api
# with App Manager access, then paste the values below.
#
# IMPORTANT: The private key contains real newlines. Replace each newline with
# the two-character sequence  \n  so the value stays on a single line, and
# wrap it in quotes. Example:
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----\n"
ASC_ISSUER_ID=
ASC_KEY_ID=
ASC_PRIVATE_KEY=

# Optional: override the SQLite data directory (defaults to ./data).
# DATA_DIR=./data

# -----------------------------------------------------------------------------
# Performance tuning (all optional)
# -----------------------------------------------------------------------------

# Locales to process in parallel per job. Higher = faster, but more
# concurrent AI calls (watch your provider rate limits). Default: 3.
# CONCURRENT_LOCALES=3

# Per-AI-call timeout in milliseconds. Raise if you see "request timed out"
# errors on slow models; lower if you'd rather fail fast and retry.
# Default: 30000 (30 s).
# AI_TIMEOUT_MS=30000

# .xcstrings: strings per AI call batch. Larger batches mean fewer round
# trips but a higher chance of hitting AI context limits. Default: 50.
# STRINGS_BATCH_SIZE=50

# .xcstrings: hard char ceiling per AI batch (caps the prompt size even when
# STRINGS_BATCH_SIZE would let it grow further). Default: 8000.
# STRINGS_MAX_CHARS_PER_BATCH=8000

# How long a job can sit in 'processing' before stale-cleanup flips it to
# 'interrupted'. Raise on slow hardware where multi-minute AI calls are
# normal; lower for snappier recovery. Default: 300000 (5 min).
# STALE_JOB_THRESHOLD_MS=300000
